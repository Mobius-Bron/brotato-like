; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="BrotatoLike"
run/main_scene="res://maps/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

DataManager="*res://core/global/data_manager.gd"
SaveManager="*res://core/global/save_manager.gd"
PlayerManager="*res://core/global/player_manager.gd"
AudioManager="*res://core/global/audio_manager.gd"
SettingsManager="*res://core/global/settings_manager.gd"
GameManager="*res://core/managers/game_manager.gd"
EventBus="*res://core/managers/event_bus.gd"
ConfigLoader="*res://core/managers/config_loader.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="BrotatoLike"

